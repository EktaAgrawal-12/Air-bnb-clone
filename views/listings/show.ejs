<% layout("/layouts/boilerplate") %>
  <div class="row mt-4">
    <!-- Title & Wishlist Header -->
    <div class="col-12 col-md-8 offset-md-2 d-flex justify-content-between align-items-center mb-3">
      <h3><b><%= listing.title%></b></h3>
      <button class="wishlist-btn" id="wishlistBtn" data-id="<%= listing._id %>" title="Add to Wishlist">
        <i class="fa-regular fa-heart" style="font-size: 1.3rem;"></i>
      </button>
    </div>

    <!-- Images Carousel (Clickable Gallery link) -->
    <div class="card col-12 col-md-8 offset-md-2 show-card listing-card shadow-sm border-0 mb-4 overflow-hidden">
      <a href="/listings/<%= listing._id %>/gallery" title="Click to view all photos" class="d-block text-decoration-none">
        <div id="listingCarousel" class="carousel slide" data-bs-ride="carousel">
          <div class="carousel-inner">
            <% if (listing.images && listing.images.length > 0) { %>
              <% listing.images.forEach((img, idx) => { %>
                <div class="carousel-item <%= idx === 0 ? 'active' : '' %>">
                  <img src="<%= img.url %>" class="d-block w-100 show-img" alt="listing_image_<%= idx %>" />
                </div>
              <% }) %>
            <% } else { %>
              <div class="carousel-item active">
                <img src="<%= listing.image && listing.image.url ? listing.image.url : 'https://images.unsplash.com/photo-1571896349842-33c89424de2d?ixlib=rb-4.0.3&auto=format&fit=crop&w=800&q=60' %>" class="d-block w-100 show-img" alt="listing_image" />
              </div>
            <% } %>
          </div>
          <% if (listing.images && listing.images.length > 1) { %>
            <button class="carousel-control-prev" type="button" data-bs-target="#listingCarousel" data-bs-slide="prev">
              <span class="carousel-control-prev-icon" aria-hidden="true"></span>
              <span class="visually-hidden">Previous</span>
            </button>
            <button class="carousel-control-next" type="button" data-bs-target="#listingCarousel" data-bs-slide="next">
              <span class="carousel-control-next-icon" aria-hidden="true"></span>
              <span class="visually-hidden">Next</span>
            </button>
          <% } %>
        </div>
      </a>
    </div>

    <!-- Main Content & Booking Calculator Layout -->
    <div class="col-12 col-md-8 offset-md-2">
      <div class="row">
        <!-- Details Column -->
        <div class="col-12 col-md-7 mb-4">
          <div class="p-3 bg-white rounded shadow-sm border mb-4">
            <h5 class="text-muted mb-3">About this destination</h5>
            <p class="card-text mb-2">Hosted by: <b class="text-capitalize text-dark"><%= listing.owner.username %></b></p>
            <hr>
            <p class="card-text text-secondary" style="line-height: 1.6;"><%= listing.description %></p>
            <hr>
            <div class="row text-center my-3">
              <div class="col-4 border-end">
                <p class="text-muted small mb-1">Price</p>
                <h5>&#8377; <%= listing.price ? listing.price.toLocaleString("en-IN") : "N/A" %></h5>
              </div>
              <div class="col-4 border-end">
                <p class="text-muted small mb-1">Location</p>
                <h6 class="text-capitalize"><%= listing.location %></h6>
              </div>
              <div class="col-4">
                <p class="text-muted small mb-1">Country</p>
                <h6><%= listing.country %></h6>
              </div>
            </div>
          </div>

          <!-- Listing Owner Actions -->
          <% if(currUser && currUser._id.equals(listing.owner._id)) {%>
            <div class="d-flex gap-2">
              <a href="/listings/<%= listing._id %>/edit" class="btn btn-secondary-action flex-grow-1 text-center">Edit Listing</a>
              <form method="POST" action="/listings/<%=listing._id%>?_method=DELETE" class="flex-grow-1">
                <button class="btn btn-primary-action w-100">Delete Listing</button>
              </form>
            </div>
          <% } %>
        </div>

        <!-- Booking Widget Column -->
        <div class="col-12 col-md-5 mb-4">
          <div class="booking-widget" data-price="<%= listing.price %>">
            <h4 class="mb-3">Book this Home</h4>
            <div class="d-flex align-items-baseline mb-3">
              <span class="price-lg">&#8377; <%= listing.price ? listing.price.toLocaleString("en-IN") : "N/A" %></span>
              <span class="text-muted ms-1">/ night</span>
            </div>
            
            <div class="booking-widget-inputs">
              <div class="booking-input-col">
                <label>Check In</label>
                <input type="date" id="checkInDate">
              </div>
              <div class="booking-input-col">
                <label>Check Out</label>
                <input type="date" id="checkOutDate">
              </div>
              <div class="booking-input-col">
                <label>Guests</label>
                <select class="form-select border-0 p-0 font-weight-bold" style="font-size: 0.95rem; outline: none; box-shadow: none;" id="guestSelect">
                  <option>1 Guest</option>
                  <option selected>2 Guests</option>
                  <option>3 Guests</option>
                  <option>4 Guests</option>
                  <option>5+ Guests</option>
                </select>
              </div>
            </div>

            <button class="btn btn-primary-action w-100 py-2 mb-3" id="bookNowBtn">Check Availability</button>

            <!-- Pricing Breakdown -->
            <table class="table table-borderless booking-widget-table mb-0" id="priceBreakdownTable">
              <tbody>
                <tr>
                  <td id="calcNightsLabel">&#8377; <%= listing.price.toLocaleString("en-IN") %> x 1 night</td>
                  <td class="text-end" id="calcBasePrice">&#8377; <%= listing.price.toLocaleString("en-IN") %></td>
                </tr>
                <tr>
                  <td>Service fee (5%)</td>
                  <td class="text-end" id="calcServiceFee">&#8377; <%= (listing.price * 0.05).toLocaleString("en-IN") %></td>
                </tr>
                <tr>
                  <td>Taxes (18% GST)</td>
                  <td class="text-end" id="calcTaxes">&#8377; <%= (listing.price * 0.18).toLocaleString("en-IN") %></td>
                </tr>
                <tr class="total-row">
                  <td>Total</td>
                  <td class="text-end" id="calcTotal">&#8377; <%= (listing.price * 1.23).toLocaleString("en-IN") %></td>
                </tr>
              </tbody>
            </table>
          </div>
        </div>
      </div>
    </div>

    <!-- Reviews Section -->
    <div class="col-12 col-md-8 offset-md-2 mb-4">
      <% if(currUser) {%>
        <hr>
        <h4 class="mb-3">Leave a Review</h4>
        <form method="POST" action="/listings/<%=listing._id%>/reviews" novalidate class="needs-validation card p-3 shadow-sm border">
          <div class="mb-3">
            <label class="form-label font-weight-bold">Rating</label>
            <fieldset class="starability-slot">
              <input type="radio" id="no-rate" class="input-no-rate" name="review[rating]" value="1" checked aria-label="No rating." />
              <input type="radio" id="first-rate1" name="review[rating]" value="1" />
              <label for="first-rate1" title="Terrible">1 star</label>
              <input type="radio" id="first-rate2" name="review[rating]" value="2" />
              <label for="first-rate2" title="Not good">2 stars</label>
              <input type="radio" id="first-rate3" name="review[rating]" value="3" />
              <label for="first-rate3" title="Average">3 stars</label>
              <input type="radio" id="first-rate4" name="review[rating]" value="4" />
              <label for="first-rate4" title="Very good">4 stars</label>
              <input type="radio" id="first-rate5" name="review[rating]" value="5" />
              <label for="first-rate5" title="Amazing">5 stars</label>
            </fieldset>
          </div>
          <div class="mb-3">
            <label for="comment" class="form-label font-weight-bold">Comments</label>
            <textarea name="review[comment]" id="comment" cols="30" rows="4" class="form-control border" placeholder="Tell us about your experience..." required></textarea>
            <div class="invalid-feedback">
              Please write a review comment.
            </div>
          </div>
          <button class="btn btn-secondary-action w-25">Submit</button>
        </form>
      <% } %>

      <% if(listing.reviews.length > 0) {%>
        <hr>
        <p class="font-weight-bold mb-3" style="font-size: 1.1rem;"><b>Reviews (<%= listing.reviews.length %>)</b></p>
        <div class="row">
          <% for(review of listing.reviews) {%> 
            <div class="col-12 col-md-6 mb-3">
              <div class="card h-100 shadow-sm border p-3">
                <div class="card-body p-0">
                  <div class="d-flex align-items-center mb-2">
                    <div class="bg-primary-light text-primary-color rounded-circle d-flex align-items-center justify-content-center text-uppercase font-weight-bold" style="width: 32px; height: 32px; font-size: 0.8rem; background-color: var(--primary-light); color: var(--primary-color);">
                      <%= review.author.username.substring(0, 2) %>
                    </div>
                    <div class="ms-2">
                      <h6 class="mb-0 text-capitalize font-weight-bold">@<%= review.author.username %></h6>
                      <span class="text-muted small"><%= new Date(review.createdAt).toLocaleDateString() %></span>
                    </div>
                  </div>
                  <p class="starability-result card-text scale-down" data-rating="<%=review.rating%>"></p>
                  <p class="card-text text-secondary font-weight-normal mt-2" style="font-size: 0.92rem;"><%= review.comment %></p>
                  <% if (currUser && (currUser._id.equals(review.author._id) || currUser._id.equals(listing.owner._id) || currUser.role === 'admin')) { %>
                    <form class="mt-3" method="POST" action="/listings/<%=listing._id%>/reviews/<%= review._id %>?_method=DELETE">
                      <button class="btn btn-sm btn-outline-danger px-3 rounded-pill"><i class="fa-solid fa-trash-can"></i> Delete</button>
                    </form>
                  <% } %>
                </div>
              </div>
            </div>
          <% } %>
        </div>
      <% } %>
    </div>

    <!-- Map Section -->
    <div class="col-12 col-md-8 offset-md-2 mb-5">
      <hr>
      <h4 class="mb-3">Where you'll be</h4>
      <div id="map" class="shadow-sm border" style="height: 350px; width: 100%; border-radius: 16px;" data-listing="<%= JSON.stringify(listing) %>"></div>
    </div>
  </div>

  <script src="/js/map.js"></script>

  <!-- Script for Bookings and Wishlist actions -->
  <script>
    document.addEventListener("DOMContentLoaded", () => {
      // 1. Wishlist Bookmark logic
      const wishlistBtn = document.getElementById("wishlistBtn");
      const listingId = wishlistBtn.dataset.id;
      
      let wishlist = JSON.parse(localStorage.getItem("wishlist") || "[]");
      
      // Update initial heart status
      if (wishlist.includes(listingId)) {
        wishlistBtn.classList.add("active");
        wishlistBtn.querySelector("i").className = "fa-solid fa-heart";
      }

      wishlistBtn.addEventListener("click", () => {
        wishlist = JSON.parse(localStorage.getItem("wishlist") || "[]");
        if (wishlist.includes(listingId)) {
          // Remove
          wishlist = wishlist.filter(id => id !== listingId);
          wishlistBtn.classList.remove("active");
          wishlistBtn.querySelector("i").className = "fa-regular fa-heart";
        } else {
          // Add
          wishlist.push(listingId);
          wishlistBtn.classList.add("active");
          wishlistBtn.querySelector("i").className = "fa-solid fa-heart";
        }
        localStorage.setItem("wishlist", JSON.stringify(wishlist));
      });

      // 2. Booking Calculator logic
      const checkInInput = document.getElementById("checkInDate");
      const checkOutInput = document.getElementById("checkOutDate");
      const priceVal = parseFloat(document.querySelector(".booking-widget").dataset.price);

      // Default dates (today & tomorrow)
      const today = new Date();
      const tomorrow = new Date(today);
      tomorrow.setDate(tomorrow.getDate() + 1);

      checkInInput.value = today.toISOString().split('T')[0];
      checkOutInput.value = tomorrow.toISOString().split('T')[0];

      function updateCalculator() {
        const checkIn = new Date(checkInInput.value);
        const checkOut = new Date(checkOutInput.value);

        if (isNaN(checkIn.getTime()) || isNaN(checkOut.getTime())) return;

        let diffTime = checkOut.getTime() - checkIn.getTime();
        let nights = Math.ceil(diffTime / (1000 * 60 * 60 * 24));

        if (nights <= 0) {
          nights = 1;
          const nextDay = new Date(checkIn);
          nextDay.setDate(nextDay.getDate() + 1);
          checkOutInput.value = nextDay.toISOString().split('T')[0];
        }

        const basePrice = priceVal * nights;
        const serviceFee = priceVal * nights * 0.05;
        const taxes = basePrice * 0.18;
        const total = basePrice + serviceFee + taxes;

        document.getElementById("calcNightsLabel").innerText = `₹ ${priceVal.toLocaleString("en-IN")} x ${nights} night${nights > 1 ? 's' : ''}`;
        document.getElementById("calcBasePrice").innerText = `₹ ${basePrice.toLocaleString("en-IN")}`;
        document.getElementById("calcServiceFee").innerText = `₹ ${serviceFee.toLocaleString("en-IN")}`;
        document.getElementById("calcTaxes").innerText = `₹ ${taxes.toLocaleString("en-IN")}`;
        document.getElementById("calcTotal").innerText = `₹ ${total.toLocaleString("en-IN")}`;
      }

      checkInInput.addEventListener("change", updateCalculator);
      checkOutInput.addEventListener("change", updateCalculator);
      updateCalculator();

      document.getElementById("bookNowBtn").addEventListener("click", () => {
        alert("Availability Confirmed! Under actual booking workflow, this would redirect you to payment gateway.");
      });
    });
  </script>

