<% layout("/layouts/boilerplate") %>

    <div id="filters" class="no-scrollbar">
      <a href="/listings?category=trending" class="filter <%= activeCategory === 'trending' ? 'active-filter' : '' %>">
        <div><i class="fa-solid fa-fire"></i></div>
        <p>Trending</p>
      </a>
      <a href="/listings?category=rooms" class="filter <%= activeCategory === 'rooms' ? 'active-filter' : '' %>">
        <div><i class="fa-solid fa-bed"></i></div>
        <p>Rooms</p>
      </a>
      <a href="/listings?category=cities" class="filter <%= activeCategory === 'cities' ? 'active-filter' : '' %>">
        <div><i class="fa-solid fa-mountain-city"></i></div>
        <p>Iconic cities</p>
      </a>
      <a href="/listings?category=mountains" class="filter <%= activeCategory === 'mountains' ? 'active-filter' : '' %>">
        <div><i class="fa-solid fa-mountain"></i></div>
        <p>Mountains</p>
      </a>
      <a href="/listings?category=castles" class="filter <%= activeCategory === 'castles' ? 'active-filter' : '' %>">
        <div><i class="fa-brands fa-fort-awesome"></i></div>
        <p>Castles</p>
      </a>
      <a href="/listings?category=pools" class="filter <%= activeCategory === 'pools' ? 'active-filter' : '' %>">
        <div><i class="fa-solid fa-person-swimming"></i></div>
        <p>Amazing Pools</p>
      </a>
      <a href="/listings?category=camping" class="filter <%= activeCategory === 'camping' ? 'active-filter' : '' %>">
        <div><i class="fa-solid fa-campground"></i></div>
        <p>Camping</p>
      </a>
      <a href="/listings?category=farms" class="filter <%= activeCategory === 'farms' ? 'active-filter' : '' %>">
        <div><i class="fa-solid fa-cow"></i></div>
        <p>Farms</p>
      </a>
      <a href="/listings?category=arctic" class="filter <%= activeCategory === 'arctic' ? 'active-filter' : '' %>">
        <div><i class="fa-solid fa-snowflake"></i></div>
        <p>Arctic</p>
      </a>
      <a href="/listings?category=domes" class="filter <%= activeCategory === 'domes' ? 'active-filter' : '' %>">
        <div><i class="fa-solid fa-igloo"></i></div>
        <p>Domes</p>
      </a>
      <a href="/listings?category=boats" class="filter <%= activeCategory === 'boats' ? 'active-filter' : '' %>">
        <div><i class="fa-solid fa-ship"></i></div>
        <p>Boats</p>
      </a>
      
      <% if (activeCategory) { %>
        <a href="/listings" class="btn btn-sm btn-outline-secondary ms-3 rounded-pill px-3 py-1">
          <i class="fa-solid fa-xmark"></i> Clear filter
        </a>
      <% } %>

      <div class="tax-toggle ms-auto">
        <div class="form-check-reverse form-switch">
          <input class="form-check-input" type="checkbox" role="switch" id="switchCheckDefault">
          <label class="form-check-label" for="switchCheckDefault">Display total after taxes</label>
        </div>
      </div>
    </div>
    
    <div class="row row-cols-lg-3 row-cols-md-2 row-cols-sm-1 mt-3">
      <% for(let listing of allListings) { %>
        <div class="col">
          <a href="/listings/<%=listing._id%>" class="listing-link">
            <div class="card listing-card h-100">
              <div class="position-relative overflow-hidden" style="height: 18rem;">
                <img src="<%= listing.image && listing.image.url ? listing.image.url : 'https://images.unsplash.com/photo-1571896349842-33c89424de2d?ixlib=rb-4.0.3&auto=format&fit=crop&w=800&q=60' %>" class="card-img-top h-100 w-100" alt="listing_image" />
              </div>
              <div class="card-body">
                <p class="card-text mb-0">
                  <b><%= listing.title %></b>
                </p>
                <div class="d-flex align-items-center justify-content-between mt-1 text-muted">
                  <span><%= listing.location %>, <%= listing.country %></span>
                  <span class="badge bg-secondary text-capitalize"><%= listing.category %></span>
                </div>
                <div class="mt-2 font-weight-bold" style="color: var(--dark-color); font-size: 1rem;">
                  &#8377; <%= listing.price ? listing.price.toLocaleString("en-IN") : "N/A" %> <span class="text-muted font-weight-normal" style="font-size: 0.85rem;">/ night</span>
                  <i class="tax-info ms-2"> &nbsp; &nbsp; +18% GST (Total: &#8377; <%= listing.price ? (listing.price * 1.18).toLocaleString("en-IN") : "N/A" %>) </i>
                </div>
              </div>
            </div>
          </a>
        </div>
      <% } %>
    </div>
    
  <script>
    let taxSwitch = document.getElementById("switchCheckDefault");
    taxSwitch.addEventListener("click", ()=>{
      let taxInfo = document.getElementsByClassName("tax-info");
      for(info of taxInfo) {
        if(info.style.display != "inline") {
          info.style.display = "inline";
        } else {
          info.style.display = "none"
        }
      }
    })
  </script>