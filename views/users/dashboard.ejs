<% layout("/layouts/boilerplate") %>

<div class="container mt-4 mb-5">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h2>Admin Dashboard</h2>
    <span class="badge bg-danger p-2 fs-6">Administrator Access Granted</span>
  </div>

  <!-- Statistics Section -->
  <div class="row mb-5">
    <div class="col-12 col-md-4 mb-3">
      <div class="admin-stat-card blue">
        <div>
          <p class="mb-0 text-uppercase small text-white-50">Total Listings</p>
          <h2 class="admin-stat-number"><%= totalListings %></h2>
          <span class="small text-white-50">Properties registered</span>
        </div>
        <i class="fa-solid fa-house"></i>
      </div>
    </div>
    <div class="col-12 col-md-4 mb-3">
      <div class="admin-stat-card red">
        <div>
          <p class="mb-0 text-uppercase small text-white-50">Registered Users</p>
          <h2 class="admin-stat-number"><%= totalUsers %></h2>
          <span class="small text-white-50">Guests & Hosts</span>
        </div>
        <i class="fa-solid fa-users"></i>
      </div>
    </div>
    <div class="col-12 col-md-4 mb-3">
      <div class="admin-stat-card green">
        <div>
          <p class="mb-0 text-uppercase small text-white-50">Total Reviews</p>
          <h2 class="admin-stat-number"><%= totalReviews %></h2>
          <span class="small text-white-50">Ratings submitted</span>
        </div>
        <i class="fa-solid fa-comments"></i>
      </div>
    </div>
  </div>

  <!-- Management Tables -->
  <div class="row">
    <!-- Listings Management -->
    <div class="col-12 col-lg-7 mb-4">
      <div class="d-flex align-items-center justify-content-between mb-3">
        <h4 class="mb-0"><i class="fa-solid fa-hotel me-2 text-danger"></i> Manage Listings</h4>
        <span class="badge bg-secondary"><%= listings.length %> listings</span>
      </div>
      
      <div class="table-responsive">
        <table class="table table-hover table-modern mb-0">
          <thead>
            <tr>
              <th>Title</th>
              <th>Location</th>
              <th>Owner</th>
              <th class="text-center">Actions</th>
            </tr>
          </thead>
          <tbody>
            <% if (listings.length === 0) { %>
              <tr>
                <td colspan="4" class="text-center text-muted">No listings found.</td>
              </tr>
            <% } else { %>
              <% listings.forEach(list => { %>
                <tr>
                  <td>
                    <div class="font-weight-bold text-dark"><%= list.title %></div>
                    <span class="text-muted small">&#8377; <%= list.price ? list.price.toLocaleString("en-IN") : "N/A" %> / night</span>
                  </td>
                  <td class="text-secondary small"><%= list.location %>, <%= list.country %></td>
                  <td class="text-capitalize small">
                    <%= list.owner ? list.owner.username : 'Unknown' %>
                  </td>
                  <td>
                    <div class="d-flex justify-content-center gap-1">
                      <a href="/listings/<%= list._id %>" class="btn btn-sm btn-outline-dark" title="View"><i class="fa-solid fa-eye"></i></a>
                      <a href="/listings/<%= list._id %>/edit" class="btn btn-sm btn-outline-secondary" title="Edit"><i class="fa-solid fa-pen"></i></a>
                      <form method="POST" action="/listings/<%= list._id %>?_method=DELETE" onsubmit="return confirm('Are you sure you want to delete this listing?')" class="d-inline">
                        <button class="btn btn-sm btn-outline-danger" title="Delete"><i class="fa-solid fa-trash-can"></i></button>
                      </form>
                    </div>
                  </td>
                </tr>
              <% }) %>
            <% } %>
          </tbody>
        </table>
      </div>
    </div>

    <!-- Users Directory -->
    <div class="col-12 col-lg-5 mb-4">
      <div class="d-flex align-items-center justify-content-between mb-3">
        <h4 class="mb-0"><i class="fa-solid fa-address-book me-2 text-primary"></i> User Directory</h4>
        <span class="badge bg-secondary"><%= users.length %> users</span>
      </div>

      <div class="table-responsive">
        <table class="table table-hover table-modern mb-0">
          <thead>
            <tr>
              <th>User Info</th>
              <th class="text-center">Role Status</th>
            </tr>
          </thead>
          <tbody>
            <% users.forEach(u => { %>
              <tr>
                <td>
                  <div class="font-weight-bold text-dark">@<%= u.username %></div>
                  <span class="text-muted small"><%= u.email %></span>
                </td>
                <td class="text-center">
                  <% if (u.role === 'admin') { %>
                    <span class="badge-role-admin text-uppercase">Admin</span>
                  <% } else { %>
                    <span class="badge-role-user text-uppercase">User</span>
                  <% } %>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    </div>
  </div>
</div>
