<% layout("/layouts/boilerplate") %>

<div class="container mt-4 mb-5">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h2><i class="fa-solid fa-house-chimney me-2"></i> Host Dashboard</h2>
    <span class="badge bg-primary p-2 fs-6">Host Portal</span>
  </div>

  <!-- Statistics Section -->
  <div class="row mb-5">
    <div class="col-12 col-md-6 mb-3">
      <div class="admin-stat-card blue">
        <div>
          <p class="mb-0 text-uppercase small text-white-50">My Listings</p>
          <h2 class="admin-stat-number"><%= totalListings %></h2>
          <span class="small text-white-50">Your active properties</span>
        </div>
        <i class="fa-solid fa-house"></i>
      </div>
    </div>
    <div class="col-12 col-md-6 mb-3">
      <div class="admin-stat-card green">
        <div>
          <p class="mb-0 text-uppercase small text-white-50">Reviews Received</p>
          <h2 class="admin-stat-number"><%= totalReviews %></h2>
          <span class="small text-white-50">Ratings on your properties</span>
        </div>
        <i class="fa-solid fa-comments"></i>
      </div>
    </div>
  </div>

  <!-- Listings Management Table -->
  <div class="row">
    <div class="col-12 mb-4">
      <div class="d-flex align-items-center justify-content-between mb-3">
        <h4 class="mb-0"><i class="fa-solid fa-hotel me-2 text-danger"></i> Manage My Listings</h4>
        <span class="badge bg-secondary"><%= listings.length %> properties registered</span>
      </div>
      
      <div class="table-responsive">
        <table class="table table-hover table-modern mb-0">
          <thead>
            <tr>
              <th>Property Title</th>
              <th>Location</th>
              <th>Status</th>
              <th class="text-center">Actions</th>
            </tr>
          </thead>
          <tbody>
            <% if (listings.length === 0) { %>
              <tr>
                <td colspan="4" class="text-center text-muted py-4">No listings added yet. Click 'Airbnb your home' to create your first listing!</td>
              </tr>
            <% } else { %>
              <% listings.forEach(list => { %>
                <tr>
                  <td>
                    <div class="font-weight-bold text-dark"><%= list.title %></div>
                    <span class="text-muted small">&#8377; <%= list.price ? list.price.toLocaleString("en-IN") : "N/A" %> / night</span>
                  </td>
                  <td class="text-secondary small"><%= list.location %>, <%= list.country %></td>
                  <td>
                    <span class="badge bg-success">Active</span>
                  </td>
                  <td>
                    <div class="d-flex justify-content-center gap-2">
                      <a href="/listings/<%= list._id %>" class="btn btn-sm btn-outline-dark px-3" title="View"><i class="fa-solid fa-eye me-1"></i> View</a>
                      <a href="/listings/<%= list._id %>/edit" class="btn btn-sm btn-outline-secondary px-3" title="Edit"><i class="fa-solid fa-pen me-1"></i> Edit</a>
                      <form method="POST" action="/listings/<%= list._id %>?_method=DELETE" onsubmit="return confirm('Are you sure you want to delete this listing?')" class="d-inline">
                        <button class="btn btn-sm btn-outline-danger px-3" title="Delete"><i class="fa-solid fa-trash-can me-1"></i> Delete</button>
                      </form>
                    </div>
                  </td>
                </tr>
              <% }) %>
            <% } %>
          </tbody>
        </table>
      </div>
    </div>
  </div>
</div>
